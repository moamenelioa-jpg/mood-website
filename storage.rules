rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // ── Payment proofs ─────────────────────────────────────────
    // Customers can UPLOAD their own receipt (write-only).
    // Only authenticated admins can READ receipts.
    match /payment_proofs/{orderNumber}/{filename} {
      // Anyone can upload (e.g. anonymous checkout flows)
      allow write: if request.resource.size < 10 * 1024 * 1024    // max 10 MB
                   && request.resource.contentType.matches('image/.*');

      // Only admins can read
      allow read: if request.auth != null
                  && request.auth.token.admin == true;
    }

    // ── Product images ──────────────────────────────────────
    // Public read. Only admins can write (upload/delete).
    match /products/{productId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.token.admin == true
                   && request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // ── Article images ──────────────────────────────────────
    match /articles/{articleId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.token.admin == true
                   && request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // ── Deny everything else ───────────────────────────────────
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
