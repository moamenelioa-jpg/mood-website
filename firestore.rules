rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.admin == true ||
        // Fallback: also treat users listed in the admins collection as admins
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // ── Orders collection ──────────────────────────────────────
    // Anyone can CREATE an order (anonymous checkout).
    // Only admins can READ, UPDATE, DELETE.
    match /orders/{orderId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // ── Admins collection ──────────────────────────────────────
    // Only admins can read the admins list.
    match /admins/{adminUid} {
      allow read, write: if isAdmin();
    }

    // ── Contact messages ──────────────────────────────────────
    // Anyone can submit a contact message (no auth required).
    // Only admins can read them.
    match /contactMessages/{messageId} {
      allow create: if request.resource.data.keys().hasAll(['fullName', 'email', 'subject', 'message'])
                    && request.resource.data.fullName is string
                    && request.resource.data.email is string
                    && request.resource.data.subject is string
                    && request.resource.data.message is string;
      allow read, update, delete: if isAdmin();
    }

    // ── Counters (order sequencing) ────────────────────────────
    // Server-side only via Admin SDK; deny direct client access.
    match /counters/{counterId} {
      allow read, write: if false;
    }

    // ── Products collection ──────────────────────────────────
    // Public read. Only admins can write.
    match /products/{productId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // ── Articles collection ───────────────────────────────────
    // Public read. Only admins can write.
    match /articles/{articleId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // ── Users collection ──────────────────────────────────────
    // Authenticated users can read and write only their own profile.
    // Admins can read any user document.
    match /users/{userId} {
      // Users can read/write ONLY their own profile, with field validations
      allow read: if isOwner(userId) || isAdmin();

      allow create: if isOwner(userId)
                    && request.resource.data.uid == userId
                    && request.resource.data.role == 'user'
                    && request.resource.data.keys().hasOnly(['uid','fullName','email','provider','emailVerified','role','createdAt','updatedAt'])
                    && request.resource.data.fullName is string
                    && request.resource.data.email is string
                    && request.resource.data.provider is string
                    && request.resource.data.emailVerified is bool
                    && request.resource.data.createdAt is timestamp
                    && request.resource.data.updatedAt is timestamp;

      allow update: if isOwner(userId)
                    // Role cannot be changed by the user
                    && request.resource.data.role == resource.data.role
                    // Prevent UID spoofing
                    && request.resource.data.uid == resource.data.uid
                    // Only allow modifying these fields
                    && request.resource.data.diff(resource.data).changedKeys().hasOnly(['fullName','email','provider','emailVerified','updatedAt'])
                    && request.resource.data.fullName is string
                    && request.resource.data.email is string
                    && request.resource.data.provider is string
                    && request.resource.data.emailVerified is bool
                    && request.resource.data.updatedAt is timestamp;

      // No deletes from clients
      allow delete: if false;
    }

    // ── Carts collection ──────────────────────────────────────
    // Authenticated users can read and write only their own cart.
    // Admins have no special access (carts are private user data).
    match /carts/{userId} {
      // Each user can only access their own cart
      allow read: if isOwner(userId);
      allow create, update: if isOwner(userId)
                            && request.resource.data.keys().hasOnly(['items','updatedAt'])
                            && request.resource.data.items is list
                            && request.resource.data.updatedAt is timestamp
                && request.resource.data.items.size() <= 200;
      // Allow a user to clear their cart (delete)
      allow delete: if isOwner(userId);
    }

    // ── Comments collection ──────────────────────────────────────
    // Any authenticated user can create a comment.
    // - text, targetId, targetType, userId, userName must be present.
    // - userId must match the authenticated caller (prevents spoofing).
    // - status is always set to "pending" by the client; server validates.
    // Only the comment owner can delete their own comment.
    // Admins can read, update (approve/reject), and delete any comment.
    match /comments/{commentId} {
      // Only authenticated users can create comments; enforce shape and limits
        allow create: if isSignedIn()
                    && request.resource.data.keys().hasAll(['targetId','targetType','userId','userName','text','status','createdAt'])
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.status == 'pending'
                    && request.resource.data.targetId is string && request.resource.data.targetId.size() > 0
                    && request.resource.data.targetType in ['blog','product']
                    && request.resource.data.userName is string && request.resource.data.userName.size() > 0 && request.resource.data.userName.size() <= 100
                    && request.resource.data.text is string && request.resource.data.text.size() > 0 && request.resource.data.text.size() <= 2000
                    && request.resource.data.createdAt is timestamp
              // rating is optional but, if present, must be 1..5 number
              && (request.resource.data.rating == null
                || (request.resource.data.rating is number && request.resource.data.rating >= 1 && request.resource.data.rating <= 5));

      // Public can read approved comments; owners and admins can read their own/unapproved
      allow read: if resource.data.status == 'approved'
                  || (isSignedIn() && resource.data.userId == request.auth.uid)
                  || isAdmin();

      // Owners can delete their own comments; admins can delete any
      allow delete: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());

      // Admin moderation: only allow status changes to approved/rejected
      allow update: if isAdmin()
                    && request.resource.data.diff(resource.data).changedKeys().hasOnly(['status'])
                    && request.resource.data.status in ['approved','rejected'];
    }

    // ── Deny everything else ───────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

